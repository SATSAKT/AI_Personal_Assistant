      "name": "Basic LLM Chain"
    },
    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst currentMonth = now.getMonth();\nconst currentYear = now.getFullYear();\n\nlet total = 0;\nconst categoryTotals = {};\n\nfor (const item of items) {\nconst row = item.json;\n\nif (!row.date || !row.amount) continue;\n\nconst rowDate = new Date(row.date);\n\nconst sameMonth =\nrowDate.getMonth() === currentMonth &&\nrowDate.getFullYear() === currentYear;\n\nif (sameMonth) {\nconst amount = Number(row.amount || 0);\nconst category = row.category || \"Other\";\n\ntotal += amount;\n\nif (!categoryTotals[category]) {\n  categoryTotals[category] = 0;\n}\n\ncategoryTotals[category] += amount;\n\n}\n}\n\nconst latestExpense = $('Edit Fields').first().json;\n\nconst emojiMap = {\nFood: \"🍔\",\nTravel: \"🚕\",\nShopping: \"🛍️\",\nEntertainment: \"🎬\",\nBills: \"💡\",\nHealth: \"🏥\",\nOther: \"📌\"\n};\n\nlet response = `✅ Expense logged successfully\\n`;\nresponse += `💰 Total spent: ₹${total}\\n`;\n\nfor (const [category, amount] of Object.entries(categoryTotals)) {\nconst emoji = emojiMap[category] || \"📌\";\nresponse += `${emoji} ${category}: ₹${amount}\\n`;\n}\n\nreturn [\n{\njson: {\nresponse\n}\n}\n];\n"
      },
